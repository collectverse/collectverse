<div class="p-3 w-100 card rounded my-3">
    <div class="d-flex justify-content-between">

        <div class="d-flex gap-3 align-items-center">
            <figure>
                <img src="https://www.tecmaran.com.br/res/imagens/blog/perfil_padrao.jpeg" class="logo rounded-circle"
                    alt="Foto de usuário">
            </figure>

            <p>{{User.dataValues.name}}</p>
        </div>

        <div>

            <div class="dropdown">
                <button class="btn btn-light p-2" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-three-dots-vertical"></i>
                </button>
                <ul class="dropdown-menu">
                    {{#if userHasComment}}
                    <li>
                        <form action="publications/delete" method="post">
                            <input type="hidden" name="id" value="{{id}}">
                            <input type="submit" class="dropdown-item" value="Deletar">
                        </form>
                    </li>
                    {{/if}}
                    <li>
                        <a href="#" class="dropdown-item">Favoritar</a>
                    </li>
                </ul>
            </div>

        </div>

    </div>

    <div>
        <p>{{content}}</p>
        {{#if hasImage}}
        <img src="{{image}}" class="w-100 rounded mb-4" alt="Imagem do comentário de {{User.dataValues.name}}">
        {{/if}}
    </div>


    <div class="d-flex justify-content-start align-items-center">

        <ul class="d-flex gap-3 ps-2 m-0">
            <li><a href="#"><i class="bi bi-hand-thumbs-up"></i></a></li>
            <li><a href="#"><i class="bi bi-chat-left-dots"></i></a></li>
            <li><a href="#"><i class="bi bi-share"></i></a></li>
        </ul>

    </div>
</div>