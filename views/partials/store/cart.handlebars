<div class="col-md-5 col-lg-4 order-md-last">
    <h4 class="d-flex justify-content-between align-items-center mb-5">
        <span class="text-primary">Seu carrinho</span>
        <span class="badge bg-primary rounded-pill">{{items.length}}</span>
    </h4>
    <ul class="list-group mb-3">

        {{#if items.length}}
        {{#each items}}
        <li class="list-group-item d-flex p-0 justify-content-between lh-sm">
            <div class="p-2">
                <div>
                    <h6 class="my-0">{{this.name}}</h6>
                    <small class="text-body-secondary">{{this.description}}</small>
                </div>
                <span class="text-body-secondary">R${{this.price}}</span>
            </div>

            <form action="/store/removeToCart" method="post">
                <input type="hidden" name="id" value="{{this.id}}">
                <input type="submit" class="btn btn-danger rounded-0 fs-4 fw-bold h-100 w-100 rounded-right" value="x">
            </form>
        </li>
        {{/each}}
        <li class="list-group-item d-flex justify-content-between">
            <span>Total (R$)</span>
            <strong>R${{total}}</strong>
        </li>
        {{else}}
        <li class="list-group-item d-flex p-0 justify-content-between lh-sm">
            <div class="p-3">
                <p class="m-0">Seu carrinho de compras está vazio.</p>
            </div>
        </li>

        {{/if}}

    </ul>

    <form class="card p-2">
        <div class="input-group">
            <input type="text" class="form-control" placeholder="Codigo">
            <input type="submit" class="btn btn-secondary" value="revindicar">
        </div>
    </form>