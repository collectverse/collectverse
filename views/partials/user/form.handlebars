<div class="p-3 w-100 card rounded my-3">
    <form action="/publications/post" method="post" class="needs-validation" class="w-100">

        <section class="d-flex gap-2">
            {{#if user}}
            <figure>
                <img src="{{user.dataValues.perfil}}" class="logo rounded-circle" alt="Foto de usuário">
            </figure>
            {{else}}
            <figure>
                <img src="https://www.tecmaran.com.br/res/imagens/blog/perfil_padrao.jpeg" class="logo rounded-circle"
                    alt="Foto de usuário">
            </figure>
            {{/if}}
            <input type="text" class="form-control form-coment rounded-pill" id="commentInput"
                placeholder="Deixe um comentário aqui!" name="content" required>
        </section>

        <footer class="d-flex justify-content-between align-items-center">
            <div>
                <ul class="d-flex gap-4 fs-5 m-0 ps-2 align-items-center justify-content-center publication-form-ul">
                    <li>
                        <button type="button" class="unset" data-toggle="modal" data-target="#archiveModal"
                            aria-label="Inserir Imagem">
                            <i class="bi bi-image" alt="Inserir Imagem"></i>
                        </button>
                    </li>
                    <li><a href="/"><i class="bi bi-paperclip" aria-label="parperclip"></i></a></li>
                </ul>
            </div>

            {{#if session.userid}}
            <input type="submit" class="px-2 rounded btn btn-light" value="Postar">
            {{else}}
            <input type="submit" class="px-2 rounded btn btn-light" value="Postar" disabled>
            {{/if}}

        </footer>

        {{> components/templates/modalarchive}}
    </form>

</div>

{{!-- internos --}}
<script src="/js/validation.js"></script>