<a href="/" class="unset" aria-label="Ir para a página {{title}}. Clique para saber mais">
    <div class="card border-dashed text-center w-100" style="max-width: 410px; height: 17.5rem;">
        <div class="card-body">
            <h2 class="card-title">{{title}}</h2>
            <p class="card-text">{{text}}</p>

            <div class="dashed-border">
                <span class="plus-icon">+</span>
            </div>
        </div>
    </div>
</a>